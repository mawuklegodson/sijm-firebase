{
  "entities": {
    "Profile": {
      "title": "Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "fullName": { "type": "string" },
        "identityRole": { "type": "string" },
        "workerPermissions": { "type": "array", "items": { "type": "string" } },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "branch": { "type": "string" },
        "dominion": { "type": "string" },
        "location": { "type": "string" },
        "birthday": { "type": "string" },
        "gender": { "type": "string" },
        "status": { "type": "string" },
        "sermonAccessSuspended": { "type": "boolean" },
        "profileUpdateRequested": { "type": "boolean" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["username", "fullName", "identityRole", "email"]
    },
    "Member": {
      "title": "Member",
      "description": "Church member information",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "gender": { "type": "string" },
        "birthday": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "location": { "type": "string" },
        "branch": { "type": "string" },
        "dominion": { "type": "string" },
        "category": { "type": "string" },
        "membershipDate": { "type": "string" },
        "followUpNeeded": { "type": "boolean" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["fullName", "gender", "location", "category", "membershipDate"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Service attendance record",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "serviceType": { "type": "string" },
        "branch": { "type": "string" },
        "segmentName": { "type": "string" },
        "maleCount": { "type": "integer" },
        "femaleCount": { "type": "integer" },
        "childrenCount": { "type": "integer" },
        "totalCount": { "type": "integer" },
        "recordedBy": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["date", "serviceType", "branch", "totalCount"]
    },
    "FirstTimer": {
      "title": "FirstTimer",
      "description": "First time visitor information",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "gender": { "type": "string" },
        "ageGroup": { "type": "string" },
        "source": { "type": "string" },
        "visitDate": { "type": "string" },
        "followUpStatus": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["fullName", "phone", "gender", "visitDate", "followUpStatus"]
    },
    "Resource": {
      "title": "Resource",
      "description": "Sermons and other church resources",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "fileUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "date": { "type": "string" },
        "author": { "type": "string" },
        "accessLevel": { "type": "string" },
        "downloadCount": { "type": "integer" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "category", "fileUrl", "accessLevel"]
    },
    "PrayerRequest": {
      "title": "PrayerRequest",
      "description": "User prayer requests",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "subject": { "type": "string" },
        "content": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "status": { "type": "string", "enum": ["Pending", "Prayed", "Answered"] },
        "createdAt": { "type": "string" },
        "category": { "type": "string" },
        "anonymous": { "type": "boolean" },
        "notes": { "type": "array", "items": { "$ref": "#/entities/PrayerNote" } },
        "visibleToIds": { "type": "array", "items": { "type": "string" } },
        "branch": { "type": "string" }
      },
      "required": ["userId", "userName", "subject", "content", "isPrivate", "status", "createdAt"]
    },
    "PrayerNote": {
      "title": "PrayerNote",
      "description": "Notes added to prayer requests",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    },
    "Event": {
      "title": "Event",
      "description": "Church events",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isRecurring": { "type": "boolean" },
        "recurringDay": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "date", "time", "location", "category", "createdAt"]
    },
    "Broadcast": {
      "title": "Broadcast",
      "description": "Site-wide marquee announcements",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "urgent", "promo"] },
        "active": { "type": "boolean" },
        "isClosable": { "type": "boolean" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "pushEnabled": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["message", "type", "active", "createdAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Ministry announcements and requests",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "urgency": { "type": "string" },
        "status": { "type": "string" },
        "submittedBy": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Book": {
      "title": "Book",
      "description": "Bookstore inventory item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "cover": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["ebook-free", "ebook-paid", "physical", "both"] },
        "price": { "type": "number" },
        "pages": { "type": "integer" },
        "description": { "type": "string" },
        "fileUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isComingSoon": { "type": "boolean" },
        "comingSoonDate": { "type": "string" },
        "featured": { "type": "boolean" },
        "new": { "type": "boolean" },
        "soldOut": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "author", "type", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Bookstore purchase record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "currency": { "type": "string" },
        "paymentGateway": { "type": "string" },
        "status": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string" }
      }
    },
    "Donation": {
      "title": "Donation",
      "description": "Financial giving record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "category": { "type": "string" },
        "paymentGateway": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Book rating and feedback",
      "type": "object",
      "properties": {
        "bookId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "profiles/{userId}": { "schema": "Profile" },
    "members/{memberId}": { "schema": "Member" },
    "attendance/{recordId}": { "schema": "Attendance" },
    "first_timers/{visitorId}": { "schema": "FirstTimer" },
    "resources/{resourceId}": { "schema": "Resource" },
    "prayer_requests/{requestId}": { "schema": "PrayerRequest" },
    "events/{eventId}": { "schema": "Event" },
    "broadcasts/{broadcastId}": { "schema": "Broadcast" },
    "announcements/{id}": { "schema": "Announcement" },
    "books/{bookId}": { "schema": "Book" },
    "orders/{orderId}": { "schema": "Order" },
    "donations/{id}": { "schema": "Donation" },
    "reviews/{id}": { "schema": "Review" },
    "settings/bookstore": { "description": "Bookstore global configuration" },
    "settings/payment": { "description": "Payment gateway global configuration" },
    "settings/global": { "description": "General ministry branding and terminology" },
    "landingPageConfigs/main": { "description": "Website hero and sections configuration" }
  }
}
